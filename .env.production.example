# Production environment template for the Anchor backend.
# Copy to your secret store / deployment config and fill in real values.
# NOTE: with APP_ENV=production the app REFUSES to boot on default secrets,
# a missing FIELD_ENCRYPTION_KEY, or APP_DEBUG=true (see app/core/config.py).

# App
APP_ENV=production
APP_DEBUG=false

# Database / Redis (use managed instances; do not expose to the internet)
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@db-host:5432/anchor
REDIS_URL=redis://redis-host:6379/0

# Auth — generate strong random values (>= 32 chars):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=
MAGIC_LINK_SECRET=

# Field-level encryption — base64 of 32 random bytes:
#   python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
FIELD_ENCRYPTION_KEY=

# CORS — the production frontend origin(s), comma-separated
CORS_ORIGINS=https://app.anchor.example

# AI — DECISION (AI-2): hosted Anthropic in production.
AI_DEFAULT_ENGINE=anthropic
ANTHROPIC_API_KEY=

# Observability
LOG_LEVEL=INFO
LOG_JSON=true
OTLP_ENDPOINT=
OTLP_SERVICE_NAME=anchor-backend
SENTRY_DSN=

# Email (password reset) — leave SMTP_HOST empty to fall back to console
# logging; set these to enable real delivery via any SMTP provider
# (SES / SendGrid / Postmark / Resend all speak SMTP).
EMAIL_FROM=noreply@anchor.example
EMAIL_FROM_NAME=Anchor
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_STARTTLS=true

# Public base URL used to build links in emails
PUBLIC_APP_URL=https://app.anchor.example
