# Database
DATABASE_URL=postgresql+asyncpg://anchor:anchor_dev@localhost:5432/anchor

# Redis
REDIS_URL=redis://localhost:6379/0

# AI Providers
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=...

# Auth
JWT_SECRET=change-me-in-production
MAGIC_LINK_SECRET=change-me-in-production

# App
APP_ENV=development
APP_DEBUG=true
CORS_ORIGINS=http://localhost:4173,http://127.0.0.1:4173

# Security — field-level encryption
# Generate: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"
FIELD_ENCRYPTION_KEY=

# Observability (OpenTelemetry)
OTLP_ENDPOINT=
OTLP_SERVICE_NAME=anchor-backend
METRICS_ENABLED=true

# Logging
LOG_LEVEL=INFO
LOG_JSON=true          # structured JSON logs; set false for readable dev logs

# Error tracking (optional — requires `uv add sentry-sdk`)
SENTRY_DSN=

# Push Notifications (VAPID)
# Generate keys: python -c "from py_vapid import Vapid; v=Vapid(); v.generate_keys(); print(v.private_key, v.public_key)"
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CONTACT_EMAIL=noreply@anchor.app

# LiveKit
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Frontend env (Vite)
VITE_VAPID_PUBLIC_KEY=
